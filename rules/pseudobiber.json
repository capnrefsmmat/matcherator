{
  "Matcher": {
    "f_01_past_tense": {
      "description": "Verbs in the past tense",
      "examples": [
        "The cat walked slowly down the street."
      ],
      "rules": [[
        {"TAG": "VBD"}
      ]]
    },

    "f_02_perfect_aspect": {
      "description": "Words in the perfect aspect, indicated by *have* as an auxiliary verb",
      "examples": [
        "I have written this sentence."
      ],
      "rules": [[
        {"LEMMA": "have", "DEP": "aux"}
      ]]
    },

    "f_03_present_tense": {
      "description": "Verbs in the present tense",
      "examples": [
        "The quick brown fox jumps over the lazy dog."
      ],
      "rules": [[
        {"TAG": {"IN": ["VBZ", "VBP"]}}
      ]]
    },

    "f_04_place_adverbials": {
      "description": "Place adverbials (e.g., *above*, *beside*, *outdoors*)",
      "examples": [
        "Far downstream, you can find the delta.",
        "I haven't found any good restaurants locally."
      ],
      "comment": "TODO 'She flew west at high speed' seems like a place adverbial, but 'west' is tagged NOUN with advmod dep. Should it count?",
      "rules": [
        [
          {"TAG": {"IN": ["RB", "RBR", "RBS", "RP"]},
           "LOWER": {"IN": [
             "aboard", "above", "abroad", "across", "ahead", "alongside",
             "around", "ashore", "astern", "away", "behind", "below", "beneath",
             "beside", "downhill", "downstairs", "downstream", "east", "far",
             "hereabouts", "indoors", "inland", "inshore", "inside", "locally",
             "near", "nearby", "north", "nowhere", "outdoors", "outside",
             "overboard", "overland", "overseas", "south", "underfoot",
             "underground", "underneath", "uphill", "upstairs", "upstream",
             "west"
           ]}
          }
        ],
        [
          {"TAG": "IN",
           "LOWER": {"IN": [
             "aboard", "above", "abroad", "across", "alongside", "around",
             "behind", "below", "beneath", "beside", "inside", "near", "nearby",
             "outside", "underneath"]}
          }
        ]
      ]
    },

    "f_05_time_adverbials": {
      "description": "Time adverbials (e.g., *early*, *instantly*, *soon*)",
      "examples": [
        "I will leave momentarily.",
        "Previously, we saw an example."
      ],
      "rules": [[
        {"TAG": {"IN": ["RB", "RBR", "RBS", "RP"]},
         "LOWER": {"IN": [
           "again", "earlier", "early", "eventually", "formerly", "immediately",
           "initially", "instantly", "late", "lately", "later", "momentarily",
           "now", "nowadays", "once", "originally", "presently", "previously",
           "recently", "shortly", "simultaneously", "subsequently", "today",
           "to-day", "tomorrow", "to-morrow", "tonight", "to-night", "yesterday"
         ]}
        }
      ]]
    },

    "f_06_first_person_pronouns": {
      "description": "First-person pronouns",
      "examples": [
        "We are very confused.",
        "I bought it for myself.",
        "Our examples are too simplistic.",
        "My cup runneth over."
      ],
      "rules": [[
        {"TAG": {"IN": ["PRP", "PRP$"]},
         "LOWER": {"IN": ["i", "me", "us", "my", "we", "our", "myself", "ourselves"]}}
      ]]
    },

    "f_07_second_person_pronouns": {
      "description": "Second-person pronouns",
      "examples": [
        "You are reading this example.",
        "I noticed that thy pants are on fire.",
        "Take control of thyself.",
        "Your simian countenance suggests a heritage unusually rich in species diversity."
      ],
      "rules": [[
        {"TAG": {"IN": ["PRP", "PRP$"]},
         "LOWER": {"IN": ["you", "your", "yourself", "yourselves", "thy", "thee",
                          "thyself", "thou"]}}
      ]]
    },

    "f_08_third_person_pronouns": {
      "description": "Third-person pronouns",
      "examples": [
        "Their pants are collectively on fire.",
        "He is a liar.",
        "When I asked her, she disagreed."
      ],
      "rules": [[
        {"TAG": {"IN": ["PRP", "PRP$"]},
         "LOWER": {"IN": [
           "she", "he", "they", "her", "him", "them", "his", "their", "himself",
           "herself", "themselves"]}}
      ]]
    },

    "f_09_pronoun_it": {
      "description": "Pronoun *it*, *its*, or *itself*",
      "examples": [
        "Its size is astounding.",
        "It destroyed itself during the attempt."
      ],
      "rules": [[
        {"TAG": {"IN": ["PRP", "PRP$"]},
         "LOWER": {"IN": ["it", "its", "itself"]}}
      ]]
    },

    "f_10_demonstrative_pronoun": {
      "description": "Demonstrative pronouns, i.e., pronouns being used to replace a noun",
      "examples": [
        "That is an example sentence."
      ],
      "rules": [
        [
          {"TAG": {"IN": ["NN", "NNS", "NNP", "NNPS",
                          "CD", "DT"]},
           "OP": "!"},
          {"TAG": "DT", "DEP": {"IN": ["nsubj", "dobj", "pobj"]},
           "LOWER": {"IN": ["that", "this", "these", "those"]}}
        ],
        [
          {"TAG": "DT", "DEP": {"IN": ["nsubj", "dobj", "pobj"]},
           "LOWER": {"IN": ["that", "this", "these", "those"]},
           "IS_SENT_START": true}
        ]
      ]
    },

    "f_11_indefinite_pronouns": {
      "description": "Indefinite pronouns (e.g., *anybody*, *nothing*, *someone*)",
      "examples": [
        "Well, someone has to do it.",
        "Nobody is ever interested in this topic.",
        "The project went nowhere.",
        "Everyone likes this example.",
        "Something's not right."
      ],
      "rules": [[
        {"LOWER": {"IN": [
          "anybody", "anyone", "anything", "everybody", "everyone",
          "everything", "nobody", "none", "nothing", "nowhere", "somebody",
          "someone", "something"
        ]}}
      ]]
    },

    "f_12_proverb_do": {
      "description": "Pro-verb *do*",
      "examples": [
        "I did it."
      ],
      "counterexamples": [
        "I do not know."
      ],
      "rules": [[
        {"LEMMA": "do", "DEP": {"NOT_IN": ["aux"]}}
      ]]
    },

    "f_13_wh_question": {
      "description": "Direct *wh-* questions",
      "examples": [
        "When are you leaving?"
      ],
      "counterexamples": [
        "I know when you are leaving."
      ],
      "rules": [
        [
          {"IS_SENT_START": true},
          {"TAG": {"IN": ["WDT", "WP", "WP$", "WRB"]},
           "POS": {"NOT_IN": ["DET"]}},
          {"DEP": "aux"}
        ],
        [
          {"TAG": {"IN": ["WDT", "WP", "WP$", "WRB"]},
           "POS": {"NOT_IN": ["DET"]},
           "IS_SENT_START": true},
          {"DEP": "aux"}
        ]
      ]
    },

    "f_14_nominalizations": {
      "description": "Nominalizations (nouns ending in *-tion*, *-ment*, *-ness*, *-ity*, e.g. *adjustment*, *abandonment*)",
      "examples": [
        "The adjustment was necessary."
      ],
      "counterexamples": [
        "I went to the station."
      ],
      "rules": [[
      {"POS": "NOUN",
       "LOWER": {"REGEX": "tion$|tions$|ment$|ments$|ness$|nesses$|ity$|ities$",
                 "NOT_IN": [
                   "apartment", "apartments", "attention", "business",
                   "businesses", "capacities", "capacity", "cities", "city",
                   "comment", "comments", "condition", "conditions", "document",
                   "documents", "edition", "editions", "element", "elements",
                   "environment", "environments", "experiment", "experiments",
                   "fiction", "fictions", "function", "functions", "humanity",
                   "identities", "identity", "mention", "mentions", "moment",
                   "moments", "motion", "motions", "nation", "nations", "notion",
                   "notions", "pity", "position", "positions", "qualities",
                   "quality", "section", "sections", "solution", "solutions",
                   "station", "stations", "tradition", "traditions",
                   "universities", "university", "witness", "witnesses"]}}
      ]]
    },

    "f_15_gerunds": {
      "description": "Gerunds (participial forms functioning as nouns)",
      "examples": [
        "Running is fun."
      ],
      "counterexamples": [
        "I am running."
      ],
      "rules": [[
      {"TAG": "VBG",
        "DEP": {"IN": ["nsubj", "obj", "obl", "conj", "nmod", "csubj",
                       "xcomp", "pcomp", "nsubjpass"]}}
      ]]
    },

    "f_19_be_main_verb": {
      "description": "*be* as main verb",
      "examples": [
        "I am happy."
      ],
      "counterexamples": [
        "I am running."
      ],
      "rules": [[
        {"LEMMA": "be", "DEP": "ROOT"}
      ]]
    },

    "f_20_existential_there": {
      "description": "Existential *there*",
      "examples": [
        "There is a feature in this sentence."
      ],
      "rules": [[
        {"TAG": "EX"}
      ]]
    },

    "f_24_infinitives": {
      "description": "Infinitives",
      "examples": [
        "I want to believe.",
        "To be involved is unwise."
      ],
      "rules": [[
        {"TAG": "TO"}
      ]]
    },

    "f_25_present_participle": {
      "description": "Present participial adverbial clauses",
      "examples": [
        "Stuffing his mouth with cookies, Joe ran out the door.",
        "Joe ran out the door, stuffing his mouth with cookies."
      ],
      "rules": [[
        {"TAG": "VBG", "DEP": {"IN": ["advcl", "ccomp"]}}
      ]]
    },

    "f_26_past_participle": {
      "description": "Past participial adverbial clauses",
      "examples": [
        "Built in a single week, the house would stand for fifty years."
      ],
      "rules": [[
        {"TAG": "VBN", "DEP": {"IN": ["advcl", "ccomp"]}}
      ]]
    },

    "f_34_sentence_relatives": {
      "description": "Sentence relatives",
      "examples": [
        "Bob likes fried mangoes, which is the most disgusting thing I've ever heard of."
      ],
      "comment": "TODO Feels like this should be done with DependencyMatcher instead of matching on commas",
      "rules": [[
        {
          "ORTH": ","
        },
        {
          "LOWER": "which",
          "DEP": "nsubj"
        }
      ]]
    },

    "f_35_because": {
      "description": "Causative adverbial subordinator (*because*)",
      "examples": [
        "I ate because I was hungry.",
        "Because I was hungry, I ate."
      ],
      "counterexamples": [
        "Because of the rain, the game was canceled."
      ],
      "comment": "TODO Check that the DEP rule here is better than checking for a following 'of'",
      "rules": [[
        {
          "LOWER": "because",
          "POS": {"IN": ["ADP", "SCONJ"]},
          "DEP": "mark"
        }
      ]]
    },

    "f_36_though": {
      "description": "Concessive adverbial subordinators (*although*, *though*)",
      "examples": [
        "Although it rained, we played.",
        "It was a good game, though it was rainy."
      ],
      "rules": [[
        {
          "LOWER": {"IN": ["though", "although", "tho"]},
          "POS": "SCONJ"
        }
      ]]
    },

    "f_37_if": {
      "description": "Conditional adverbial subordinators (*if*, *unless*)",
      "examples": [
        "If it rains, we stay inside."
      ],
      "rules": [[
        {
          "LOWER": {"IN": ["if", "unless"]},
          "POS": "SCONJ"
        }
      ]]
    },

    "f_38_other_adv_sub": {
      "description": "Other adverbial subordinators (*since*, *while*, *whereas*)",
      "examples": [
        "Since it rained, we stayed inside."
      ],
      "comment": "TODO 'It's been raining since noon' should not match, but does.",
      "rules": [[
        {
          "LOWER": {"IN": ["since", "while", "whereas"]},
          "POS": "SCONJ"
        }
      ]]
    },

    "f_39_prepositions": {
      "description": "Total prepositional phrases",
      "rules": [[
        {"DEP": "prep"}
      ]]
    },

    "f_40_adj_attr": {
      "description": "Attributive adjectives",
      "examples": [
        "The big horse is here."
      ],
      "counterexamples": [
        "The horse is big."
      ],
      "rules": [[
        {"POS": "ADJ", "DEP": "amod"}
      ]]
    },

    "f_41_adj_pred": {
      "description": "Predicative adjectives",
      "examples": [
        "The horse is big."
      ],
      "counterexamples": [
        "The big horse is here."
      ],
      "rules": [[
        {"POS": "ADJ", "DEP": "acomp"}
      ]]
    },

    "f_42_adverbs": {
      "description": "Total adverbs",
      "examples": [
      ],
      "rules": [[
        {"TAG": {"IN": ["RB", "RBR", "RBS", "WRB"]}}
      ]]
    },

    "f_49_emphatics": {
      "description": "Emphatics",
      "examples": [
        "The horse is so big.",
        "He did do it.",
        "It's a real big problem."
      ],
      "rules": [
        [
          {"LOWER": {"IN": ["so", "real"]}},
          {"TAG": "JJ"}
        ],
        [
          {"LOWER": {"IN": ["do", "does", "doing", "did"]},
           "TAG": {"IN": ["VB", "VBD", "VBG", "VBN", "VBP", "VBN", "VBP", "VBZ"]}},
          {"POS": "VERB"}
        ]
      ]
    },

    "f_50_discourse_particles": {
      "description": "Discourse particles",
      "examples": [
        "Well, that's not a good idea.",
        "Anyway, I started blasting.",
        "She tried it, but, well, it didn't work."
      ],
      "counterexamples": [
        "He dug a well."
      ],
      "rules": [
        [
          {"IS_PUNCT": true},
          {"LOWER": {"IN": ["well", "now", "anyhow", "anyways", "anyway"]}}
        ],
        [
          {"IS_SENT_START": true,
           "LOWER": {"IN": ["well", "now", "anyhow", "anyways", "anyway"]}}
        ]

      ]
    },

    "f_51_demonstratives": {
      "description": "Demonstratives (*that*, *this*, *these*, or *those* used as determiners)",
      "examples": [
        "That is the feature.",
        "This cat is happy.",
        "Those are my penguins."
      ],
      "rules": [[
        {"TAG": "DT",
         "LOWER": {"IN": ["that", "this", "these", "those"]}}
      ]]
    },

    "f_52_modal_possibility": {
      "description": "Possibility modals",
      "examples": [
        "You can do it!",
        "The bridge might fall down."
      ],
      "counterexamples": [
        "Stand in awe of my might."
      ],
      "rules": [[
        {"LEMMA": {"IN": ["can", "may", "might", "could"]},
         "TAG": "MD"}
      ]]
    },

    "f_53_modal_necessity": {
      "description": "Necessity modals",
      "examples": [
        "You should wright more examples.",
        "One must write examples."
      ],
      "counterexamples": [
        "It smells very musty in here."
      ],
      "rules": [[
        {"LEMMA": {"IN": ["ought", "should", "must"]},
         "TAG": "MD"}
      ]]
    },

    "f_54_modal_predictive": {
      "description": "Predictive modals",
      "examples": [
        "You will read this example.",
        "It shall be done."
      ],
      "counterexamples": [
        "He wrote a will."
      ],
      "rules": [[
        {"LEMMA": {"IN": ["will", "would", "shall"]},
         "TAG": "MD"}
      ]]
    },

    "f_55_verb_public": {
      "description": "Public verbs",
      "examples": [
        "He announced his opinions.",
        "She remarked that this example is stupid.",
        "I do solemly swear that this is an example."
      ],
      "counterexamples": [
        "This is a swear word.",
        "He placed a bet."
      ],
      "rules": [[
        {
          "POS": "VERB",
          "LEMMA": {"IN": [
            "acknowledge", "add", "admit", "affirm", "agree", "allege", "announce",
            "argue", "assert", "bet", "boast", "certify", "claim", "comment",
            "complain", "concede", "confess", "confide", "confirm", "contend",
            "convey", "declare", "deny", "disclose", "exclaim", "explain",
            "forecast", "foretell", "guarantee", "hint", "insist", "maintain",
            "mention", "object", "predict", "proclaim", "promise", "pronounce",
            "prophesy", "protest", "remark", "repeat", "reply", "report", "say",
            "state", "submit", "suggest", "swear", "testify", "vow", "warn",
            "write"]}
        }
      ]]
    },

    "f_56_verb_private": {
      "description": "Private verbs",
      "examples": [
        "I anticipate a raise.",
        "I did not realise the issue.",
        "She thinks it's an issue."
      ],
      "rules": [[
        {
          "POS": "VERB",
          "LEMMA": {"IN": [
            "accept", "anticipate", "ascertain", "assume", "believe", "calculate",
            "check", "conclude", "conjecture", "consider", "decide", "deduce",
            "deem", "demonstrate", "determine", "discern", "discover", "doubt",
            "dream", "ensure", "establish", "estimate", "expect", "fancy", "fear",
            "feel", "find", "foresee", "forget", "gather", "guess", "hear",
            "hold", "hope", "imagine", "imply", "indicate", "infer", "insure",
            "judge", "know", "learn", "mean", "note", "notice", "observe",
            "perceive", "presume", "presuppose", "pretend", "prove", "realize",
            "realise",
            "reason", "recall", "reckon", "recognize", "reflect", "remember",
            "reveal", "see", "sense", "show", "signify", "suppose", "suspect",
            "think", "understand"
          ]}
        }
      ]]
    },

    "f_57_verb_suasive": {
      "description": "Suasive verbs",
      "examples": [
        "She decreed that none will survive.",
        "I will ensure that you succeed.",
        "They urged us to accept the proposal urgently."
      ],
      "counterexamples": [
        "We followed the rules.",
        "She read the decree."
      ],
      "rules": [[
        {
          "POS": "VERB",
          "LEMMA": {"IN": [
            "agree", "allow", "arrange", "ask", "beg", "command", "concede",
            "decide", "decree", "decreed", "demand", "desire", "determine", "enjoin",
            "ensure", "entreat", "grant", "insist", "instruct", "intend",
            "move", "ordain", "order", "pledge", "pray", "prefer", "pronounce",
            "propose", "recommend", "request", "require", "resolve", "rule",
            "stipulate", "suggest", "urge", "vote"
          ]}
        }
      ]]
    }
  },

  "f_58_verb_seem": {
    "description": "Verbs *seem* and *appear*",
    "examples": [
      "It seems to be the case.",
      "It appears to be the case.",
      "It just appeared in front of me!",
      "While they were appearing, one went missing."
    ],
    "rules": [[
      {"POS": "VERB",
       "LEMMA": {"IN": ["seem", "appear"]}}
    ]]
  },

  "f_59_contractions": {
    "description": "Contractions",
    "examples": [
      "I can't do it.",
      "They won't do it.",
      "You shouldn't be involved.",
      "They'll do it.",
      "You could've done it.",
      "It's a good idea.",
      "She's a great teacher.",
      "They're going to do it."
    ],
    "counterexamples": [
      "The truck's fender was damaged.",
      "Bob's truck was damaged."
    ],
    "rules": [[
      {"LOWER": {"REGEX": "'"},
       "TAG": {"IN": ["MD", "RB", "VBZ", "VBP"]}}
    ]]
  },

  "DependencyMatcher": {
    "f_TODO_all_passives": {
      "description": "All passives",
      "examples": [
        "The task was done.",
        "The task was done by Steve."
      ],
      "rules": [[
        {
          "RIGHT_ID": "passive_verb",
          "RIGHT_ATTRS": {"TAG": "VBN"}
        },
        {
          "LEFT_ID": "passive_verb",
          "REL_OP": ">",
          "RIGHT_ID": "aux_pass",
          "RIGHT_ATTRS": {"DEP": "auxpass"}
        }
      ]]
    },

    "f_18_by_passives": {
      "description": "*by-* passives",
      "examples": [
        "The task was done by Steve."
      ],
      "counterexamples": [
        "The task was done.",
        "By beginning this sentence with \"by\", I may break the feature detector."
      ],
      "rules": [[
        {
          "RIGHT_ID": "passive_verb",
          "RIGHT_ATTRS": {"TAG": "VBN"}
        },
        {
          "LEFT_ID": "passive_verb",
          "REL_OP": ">",
          "RIGHT_ID": "aux_pass",
          "RIGHT_ATTRS": {"DEP": "auxpass"}
        },
        {
          "LEFT_ID": "passive_verb",
          "REL_OP": ">",
          "RIGHT_ID": "agent_node",
          "RIGHT_ATTRS": {"DEP": "agent"}
        }
      ]]
    },

    "f_21_that_verb_comp": {
      "description": "*that* verb complements",
      "examples": [
        "I said that he went."
      ],
      "rules": [[
        {
          "RIGHT_ID": "verb",
          "RIGHT_ATTRS": {"POS": "VERB"}
        },
        {
          "LEFT_ID": "verb",
          "REL_OP": ">",
          "RIGHT_ID": "comp_verb",
          "RIGHT_ATTRS": {"DEP": "ccomp", "POS": "VERB"}
        },
        {
          "LEFT_ID": "comp_verb",
          "REL_OP": ">",
          "RIGHT_ID": "that_comp",
          "RIGHT_ATTRS": {"DEP": "mark", "LOWER": "that", "POS": "SCONJ"}
        }
      ]]
    },

    "f_22_that_adj_comp": {
      "description": "*that* adjective complements",
      "examples": [
        "I'm glad that you like it."
      ],
      "rules": [[
        {
          "RIGHT_ID": "adjective",
          "RIGHT_ATTRS": {"POS": "ADJ"}
        },
        {
          "LEFT_ID": "adjective",
          "REL_OP": ">",
          "RIGHT_ID": "comp_verb",
          "RIGHT_ATTRS": {"DEP": "ccomp", "POS": "VERB"}
        },
        {
          "LEFT_ID": "comp_verb",
          "REL_OP": ">",
          "RIGHT_ID": "that_comp",
          "RIGHT_ATTRS": {"DEP": "mark", "LOWER": "that", "POS": "SCONJ"}
        }
      ]]
    },

    "f_23_wh_clause": {
      "description": "*wh-* clauses",
      "examples": [
        "I believed what he told me."
      ],
      "comment": "TODO What about 'I believed in what he told me' or 'I believed a little of what he told me'?",
      "rules": [[
        {
          "RIGHT_ID": "root_verb",
          "RIGHT_ATTRS": {"POS": "VERB"}
        },
        {
          "LEFT_ID": "root_verb",
          "REL_OP": ">",
          "RIGHT_ID": "subordinate_verb",
          "RIGHT_ATTRS": {"POS": "VERB", "DEP": "ccomp"}
        },
        {
          "LEFT_ID": "subordinate_verb",
          "REL_OP": ">",
          "RIGHT_ID": "wh-",
          "RIGHT_ATTRS": {"TAG": {"IN": ["WP", "WP$", "WRB"]},
                          "DEP": "dative"}
        }
      ]]
    },

    "f_27_past_participle_whiz": {
      "description": "Past participial postnominal (reduced relative) clauses",
      "examples": [
        "The solution produced by this process is effective."
      ],
      "rules": [[
        {
          "RIGHT_ID": "noun",
          "RIGHT_ATTRS": {"POS": "NOUN"}
        },
        {
          "LEFT_ID": "noun",
          "REL_OP": ">",
          "RIGHT_ID": "past_participle",
          "RIGHT_ATTRS": {"DEP": "acl", "TAG": "VBN"}
        }
      ]]
